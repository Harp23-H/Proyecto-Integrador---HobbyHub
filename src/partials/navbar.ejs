<nav class="bg-white shadow-sm border-b border-[#D9D9D9]">
    <!-- Mostrar mensajes de éxito/error -->
<% if (message) { %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
        <span class="block sm:inline"><%= message %></span>
    </div>
<% } %>

<% if (error) { %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
        <span class="block sm:inline"><%= error %></span>
    </div>
<% } %>
    <div class="container mx-auto px-4">
        <div class="flex justify-between items-center h-16">
            <!-- Logo -->
            <a href="/" class="text-2xl font-bold text-[#FB923C]">
                HobbyHub
            </a>
            
            <!-- Menú -->
            <div class="flex items-center space-x-4">
                <a href="/feed/explore" class="text-[#1E1E1E] hover:text-[#FB923C] transition">
                    Explorar
                </a>
                
                <% if (user) { %>
                    <a href="/profile/my-profile" class="text-[#1E1E1E] hover:text-[#FB923C] transition">
                        Perfil
                    </a>
                    <a href="/auth/logout" class="bg-[#FB923C] text-white px-4 py-2 rounded-lg hover:bg-[#FB923C]/90 transition">
                        Cerrar sesión
                    </a>
                <% } else { %>
                    <a href="/auth/login" class="text-[#1E1E1E] hover:text-[#FB923C] transition">
                        Iniciar sesión
                    </a>
                    <a href="/auth/register" class="bg-[#FB923C] text-white px-4 py-2 rounded-lg hover:bg-[#FB923C]/90 transition">
                        Registrarse
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</nav>