<nav class="bg-white shadow-sm border-b border-[#D9D9D9]">
    <div class="container mx-auto px-4">
        <div class="flex justify-between items-center h-16">
            <!-- Logo -->
            <a href="/" class="text-2xl font-bold text-[#8B5CF6]">
                HobbyHub
            </a>
            
            <!-- Barra de búsqueda (solo visible en desktop) -->
            <form method="GET" action="/profile/search/results" class="hidden md:flex flex-1 max-w-md mx-4">
                <input type="text" name="q" placeholder="Buscar usuarios o publicaciones..."
                       class="w-full px-4 py-2 border border-[#D9D9D9] rounded-l-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none">
                <button type="submit" class="bg-[#8B5CF6] text-white px-4 rounded-r-lg hover:bg-[#8B5CF6]/90">
                    🔍
                </button>
            </form>
            
            <!-- Menú -->
            <div class="flex items-center space-x-4">
                
                <a href="/my-courses" class="text-[#1E1E1E] hover:text-[#8B5CF6] transition">
                    Cursos
                </a>
                
                <a href="/feed/explore" class="text-[#1E1E1E] hover:text-[#8B5CF6] transition">
                    Explorar
                </a>

                <% if (user) { %>
                    <a href="/feed/home" class="text-[#1E1E1E] hover:text-[#8B5CF6] transition">
                        Inicio
                    </a>
                    <a href="/posts/create" class="text-[#1E1E1E] hover:text-[#8B5CF6] transition">
                        + Crear
                    </a>
                    <a href="/profile/me/profile" class="flex items-center gap-2">
                        <img src="<%= user.fotoPerfil %>" class="w-8 h-8 rounded-full object-cover">
                    </a>
                <% } else { %>
                    <a href="/auth/login" class="text-[#1E1E1E] hover:text-[#8B5CF6] transition">
                        Iniciar sesión
                    </a>
                    <a href="/auth/register" class="bg-[#8B5CF6] text-white px-4 py-2 rounded-lg hover:bg-[#8B5CF6]/90 transition">
                        Registrarse
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</nav>