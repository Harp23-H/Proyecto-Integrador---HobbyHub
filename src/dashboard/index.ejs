<div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold text-[#1E1E1E] mb-8">Mi Dashboard</h1>
    
    <!-- Sección de estadísticas del alumno -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-[#EDE9FE] rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-[#8B5CF6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm text-[#1E1E1E]/60">Cursos contratados</p>
                    <p class="text-2xl font-bold text-[#1E1E1E]"><%= alumnoStats.total %></p>
                </div>
            </div>
        </div>
        
        <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm text-[#1E1E1E]/60">En progreso</p>
                    <p class="text-2xl font-bold text-[#1E1E1E]"><%= alumnoStats.activos %></p>
                </div>
            </div>
        </div>
        
        <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm text-[#1E1E1E]/60">Completados</p>
                    <p class="text-2xl font-bold text-[#1E1E1E]"><%= alumnoStats.completados %></p>
                </div>
            </div>
        </div>
        
        <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-[#FFF59D] rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-[#1E1E1E]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm text-[#1E1E1E]/60">Total gastado</p>
                    <p class="text-2xl font-bold text-[#1E1E1E]">$<%= alumnoStats.totalGastado %></p>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Mis cursos contratados -->
    <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] overflow-hidden mb-8">
        <div class="p-4 border-b border-[#D9D9D9]">
            <h2 class="text-xl font-bold text-[#1E1E1E]">Mis cursos contratados</h2>
        </div>
        
        <div class="divide-y divide-[#D9D9D9]">
            <% if (misCursos && misCursos.length > 0) { %>
                <% misCursos.forEach(enrollment => { %>
                    <div class="p-4 hover:bg-gray-50 transition">
                        <div class="flex flex-col md:flex-row gap-4">
                            <img src="<%= enrollment.curso.imagenUrl %>" class="w-full md:w-32 h-24 object-cover rounded-lg">
                            <div class="flex-1">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <a href="/dashboard/my-course/<%= enrollment.id %>" class="text-lg font-semibold text-[#1E1E1E] hover:text-[#8B5CF6]">
                                            <%= enrollment.curso.titulo %>
                                        </a>
                                        <p class="text-sm text-[#1E1E1E]/60">
                                            Por @<%= enrollment.curso.experto.username %>
                                        </p>
                                    </div>
                                    <span class="px-3 py-1 rounded-full text-xs
                                        <%= enrollment.estado === 'completado' ? 'bg-green-100 text-green-700' :
                                           enrollment.estado === 'cancelado' ? 'bg-red-100 text-red-700' :
                                           'bg-[#EDE9FE] text-[#8B5CF6]' %>">
                                        <%= enrollment.estado === 'completado' ? '✅ Completado' :
                                           enrollment.estado === 'cancelado' ? '❌ Cancelado' :
                                           enrollment.estado === 'en_progreso' ? '📚 En progreso' : '🎯 Confirmado' %>
                                    </span>
                                </div>
                                
                                <!-- Barra de progreso -->
                                <div class="mt-3">
                                    <div class="flex justify-between text-sm mb-1">
                                        <span>Progreso</span>
                                        <span><%= enrollment.progreso || 0 %>%</span>
                                    </div>
                                    <div class="w-full bg-[#D9D9D9] rounded-full h-2">
                                        <div class="bg-[#8B5CF6] h-2 rounded-full" style="width: <%= enrollment.progreso || 0 %>%"></div>
                                    </div>
                                </div>
                                
                                <div class="flex gap-4 mt-3 text-sm text-[#1E1E1E]/60">
                                    <span>💰 Pagado: $<%= enrollment.montoPagado %></span>
                                    <span>📅 <%= new Date(enrollment.fechaInscripcion).toLocaleDateString('es-MX') %></span>
                                </div>
                            </div>
                            <div class="flex items-center">
                                <a href="/dashboard/my-course/<%= enrollment.id %>" 
                                   class="bg-[#8B5CF6] text-white px-4 py-2 rounded-lg text-sm hover:bg-[#8B5CF6]/90 transition">
                                    Ver curso
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="p-8 text-center">
                    <p class="text-[#1E1E1E]/60">Aún no has contratado ningún curso</p>
                    <a href="/courses" class="inline-block mt-4 text-[#8B5CF6] hover:underline">Explorar cursos →</a>
                </div>
            <% } %>
        </div>
    </div>
    
    <!-- Sección de Experto (si es experto) -->
    <% if (esExperto) { %>
        <div class="bg-gradient-to-r from-[#8B5CF6] to-[#C4B5FD] rounded-xl p-6 mb-8 text-white">
            <div class="flex justify-between items-center">
                <div>
                    <h2 class="text-2xl font-bold">Eres Experto</h2>
                    <p class="opacity-90">Comparte tu pasión y gana dinero enseñando</p>
                </div>
                <a href="/courses/create" class="bg-white text-[#8B5CF6] px-6 py-2 rounded-lg font-semibold hover:bg-gray-100">
                    + Crear nuevo curso
                </a>
            </div>
        </div>
        
        <!-- Estadísticas de experto -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-4">
                <p class="text-sm text-[#1E1E1E]/60">Cursos creados</p>
                <p class="text-2xl font-bold text-[#1E1E1E]"><%= expertoStats.total %></p>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-4">
                <p class="text-sm text-[#1E1E1E]/60">Alumnos totales</p>
                <p class="text-2xl font-bold text-[#1E1E1E]"><%= expertoStats.alumnosTotales %></p>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-4">
                <p class="text-sm text-[#1E1E1E]/60">Ingresos totales</p>
                <p class="text-2xl font-bold text-[#1E1E1E]">$<%= expertoStats.ingresosTotales %></p>
            </div>
        </div>
        
        <!-- Mis cursos como experto -->
        <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] overflow-hidden">
            <div class="p-4 border-b border-[#D9D9D9] flex justify-between items-center">
                <h2 class="text-xl font-bold text-[#1E1E1E]">Mis cursos impartidos</h2>
                <a href="/dashboard/expert-stats" class="text-[#8B5CF6] text-sm hover:underline">Ver estadísticas →</a>
            </div>
            
            <div class="divide-y divide-[#D9D9D9]">
                <% if (expertoCursos && expertoCursos.length > 0) { %>
                    <% expertoCursos.forEach(course => { %>
                        <div class="p-4 hover:bg-gray-50 transition">
                            <div class="flex flex-col md:flex-row gap-4">
                                <img src="<%= course.imagenUrl %>" class="w-full md:w-32 h-24 object-cover rounded-lg">
                                <div class="flex-1">
                                    <a href="/courses/<%= course.id %>" class="text-lg font-semibold text-[#1E1E1E] hover:text-[#8B5CF6]">
                                        <%= course.titulo %>
                                    </a>
                                    <div class="flex gap-4 mt-2 text-sm text-[#1E1E1E]/60">
                                        <span>📊 <%= course.inscritosCount || 0 %> alumnos</span>
                                        <span>⭐ <%= course.rating || 0 %></span>
                                        <span>💰 $<%= course.precio %></span>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <a href="/dashboard/course-students/<%= course.id %>" 
                                       class="text-[#8B5CF6] hover:underline text-sm">
                                        Ver alumnos →
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="p-8 text-center">
                        <p class="text-[#1E1E1E]/60">Aún no has creado ningún curso</p>
                        <a href="/courses/create" class="inline-block mt-4 text-[#8B5CF6] hover:underline">Crear mi primer curso →</a>
                    </div>
                <% } %>
            </div>
        </div>
    <% } %>
    
    <!-- Botón para hacerse experto (si no lo es) -->
    <% if (!esExperto) { %>
        <div class="bg-[#EDE9FE] rounded-xl p-6 text-center">
            <h3 class="text-xl font-bold text-[#1E1E1E] mb-2">¿Eres un experto en tu hobby?</h3>
            <p class="text-[#1E1E1E]/60 mb-4">Comparte tus conocimientos creando cursos y talleres</p>
            <button onclick="hacerseExperto()" class="bg-[#8B5CF6] text-white px-6 py-2 rounded-lg hover:bg-[#8B5CF6]/90">
                Hacerse experto
            </button>
        </div>
    <% } %>
</div>

<script>
async function hacerseExperto() {
    try {
        const response = await fetch('/profile/me/make-expert', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const data = await response.json();
        
        if (data.success) {
            location.reload();
        }
    } catch (error) {
        console.error('Error:', error);
        alert('Error al hacerse experto');
    }
}
</script>