<div class="max-w-6xl mx-auto">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-[#1E1E1E]">Mis Talleres</h1>
        <a href="/courses/create" class="bg-[#8B5CF6] text-white px-4 py-2 rounded-lg hover:bg-[#8B5CF6]/90">
            + Crear nuevo taller
        </a>
    </div>
    
    <% if (courses && courses.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% courses.forEach(course => { %>
                <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] overflow-hidden hover:shadow-md transition">
                    <img src="<%= course.imagenUrl %>" class="w-full h-48 object-cover">
                    <div class="p-4">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-semibold text-[#1E1E1E]"><%= course.titulo %></h3>
                            <span class="text-xs px-2 py-1 rounded-full <%= course.modalidad === 'online' ? 'bg-blue-100 text-blue-600' : 'bg-purple-100 text-purple-600' %>">
                                <%= course.modalidad === 'online' ? '💻 En línea' : '📍 Presencial' %>
                            </span>
                        </div>
                        <p class="text-sm text-[#1E1E1E]/60 line-clamp-2 mb-3"><%= course.descripcion %></p>
                        <p class="text-[#8B5CF6] font-bold mb-3">$<%= course.precio %> MXN</p>
                        <div class="flex gap-2">
                            <a href="/courses/<%= course.id %>" class="flex-1 text-center text-[#8B5CF6] border border-[#8B5CF6] py-1 rounded-lg text-sm hover:bg-[#8B5CF6] hover:text-white transition">
                                Ver
                            </a>
                            <a href="/courses/edit/<%= course.id %>" class="flex-1 text-center bg-[#8B5CF6] text-white py-1 rounded-lg text-sm hover:bg-[#8B5CF6]/90">
                                Editar
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-12 text-center">
            <p class="text-[#1E1E1E]/60 mb-4">Aún no has creado ningún taller</p>
            <a href="/courses/create" class="inline-block bg-[#8B5CF6] text-white px-6 py-2 rounded-lg hover:bg-[#8B5CF6]/90">
                Crear mi primer taller
            </a>
        </div>
    <% } %>
</div>