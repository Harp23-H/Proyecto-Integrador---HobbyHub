<style>
    .tab-btn.active {
        background-color: #8B5CF6;
        color: white;
    }
    .tab-btn:not(.active) {
        background-color: #f3f4f6;
        color: #1E1E1E;
    }
    .tab-pane {
        display: none;
    }
    .tab-pane.active {
        display: block;
    }
</style>

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] overflow-hidden">
        <div class="p-6">
            <h1 class="text-2xl font-bold text-[#1E1E1E] mb-2">Crear nuevo taller</h1>
            <p class="text-[#1E1E1E]/60 mb-6">Comparte tu conocimiento con la comunidad</p>
            
            <form method="POST" action="/courses/create" id="courseForm">
                <!-- Información básica -->
                <div class="space-y-6">
                    <!-- Título -->
                    <div>
                        <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                            Título del taller *
                        </label>
                        <input type="text" name="titulo" required
                               class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none"
                               placeholder="Ej: Introducción a la pintura de miniaturas">
                    </div>
                    
                    <!-- Descripción -->
                    <div>
                        <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                            Descripción *
                        </label>
                        <textarea name="descripcion" rows="4" required
                                  class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none"
                                  placeholder="Describe de qué trata tu taller..."></textarea>
                    </div>
                    
                    <!-- Modalidad -->
                    <div>
                        <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                            Modalidad *
                        </label>
                        <div class="flex gap-3">
                            <button type="button" id="onlineTab" class="tab-btn px-6 py-2 rounded-lg transition">
                                En línea
                            </button>
                            <button type="button" id="presentialTab" class="tab-btn px-6 py-2 rounded-lg transition">
                                Presencial
                            </button>
                        </div>
                        <input type="hidden" name="modalidad" id="modalidad" value="online">
                    </div>
                    
                    <!-- Campos para modalidad ONLINE -->
                    <div id="onlineFields" class="tab-pane active space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                                Plataforma
                            </label>
                            <select name="plataforma" class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg">
                                <option value="zoom">Zoom</option>
                                <option value="meet">Google Meet</option>
                                <option value="teams">Microsoft Teams</option>
                            </select>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                                Horarios disponibles
                            </label>
                            <div id="horariosContainer" class="space-y-2">
                                <div class="flex gap-2">
                                    <select name="horario_dia[]" class="flex-1 px-3 py-2 border border-[#D9D9D9] rounded-lg">
                                        <option value="Lunes">Lunes</option>
                                        <option value="Martes">Martes</option>
                                        <option value="Miércoles">Miércoles</option>
                                        <option value="Jueves">Jueves</option>
                                        <option value="Viernes">Viernes</option>
                                        <option value="Sábado">Sábado</option>
                                        <option value="Domingo">Domingo</option>
                                    </select>
                                    <input type="time" name="horario_hora[]" class="px-3 py-2 border border-[#D9D9D9] rounded-lg">
                                    <button type="button" onclick="removeHorario(this)" class="text-red-500">✕</button>
                                </div>
                            </div>
                            <button type="button" onclick="addHorario()" 
                                    class="mt-2 text-[#8B5CF6] text-sm hover:underline">
                                + Agregar otro horario
                            </button>
                        </div>
                    </div>
                    
                    <!-- Campos para modalidad PRESENCIAL -->
                    <div id="presentialFields" class="tab-pane space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                                Ubicación del taller *
                            </label>
                            <div class="flex gap-2">
                                <input type="text" id="direccion" name="direccion"
                                       placeholder="Calle, número, colonia, ciudad"
                                       class="flex-1 px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none">
                                <button type="button" onclick="openMapModal()"
                                        class="bg-[#8B5CF6] text-white px-4 py-3 rounded-lg hover:bg-[#8B5CF6]/90 transition">
                                    Mapa
                                </button>
                            </div>
                            <input type="hidden" id="ubicacionLat" name="ubicacionLat">
                            <input type="hidden" id="ubicacionLng" name="ubicacionLng">
                            <div id="selectedLocationDisplay" class="mt-2 hidden">
                                <p class="text-sm text-[#8B5CF6]">
                                    <span id="selectedLocationText"></span>
                                </p>
                            </div>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                                Horario general
                            </label>
                            <div class="grid grid-cols-2 gap-2">
                                <input type="text" name="horario_sabado" placeholder="Sábado → 4:00 p.m"
                                       class="px-3 py-2 border border-[#D9D9D9] rounded-lg">
                                <input type="text" name="horario_domingo" placeholder="Domingo → 11:00 a.m"
                                       class="px-3 py-2 border border-[#D9D9D9] rounded-lg">
                            </div>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                                Requisitos presenciales
                            </label>
                            <textarea name="requisitos" rows="3"
                                      class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none"
                                      placeholder="- Llevar tu instrumento&#10;- Llegar 10 minutos antes&#10;- Traer material propio"></textarea>
                        </div>
                    </div>
                    
                    <!-- Materiales necesarios -->
                    <div>
                        <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                            Materiales necesarios
                        </label>
                        <div id="materialesContainer" class="space-y-2">
                            <div class="flex gap-2">
                                <input type="text" name="materiales[]" placeholder="Ej: Guitarra"
                                       class="flex-1 px-3 py-2 border border-[#D9D9D9] rounded-lg">
                                <button type="button" onclick="removeMaterial(this)" class="text-red-500">✕</button>
                            </div>
                        </div>
                        <button type="button" onclick="addMaterial()" 
                                class="mt-2 text-[#8B5CF6] text-sm hover:underline">
                            + Agregar material
                        </button>
                    </div>
                    
                    <!-- Módulos -->
                    <div>
                        <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                            Módulos del curso
                        </label>
                        <div id="modulosContainer" class="space-y-2">
                            <div class="flex gap-2">
                                <input type="text" name="modulos[]" placeholder="Ej: Módulo 1: Introducción"
                                       class="flex-1 px-3 py-2 border border-[#D9D9D9] rounded-lg">
                                <button type="button" onclick="removeModulo(this)" class="text-red-500">✕</button>
                            </div>
                        </div>
                        <button type="button" onclick="addModulo()" 
                                class="mt-2 text-[#8B5CF6] text-sm hover:underline">
                            + Agregar módulo
                        </button>
                    </div>
                    
                    <!-- Nivel y duración -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                                Nivel
                            </label>
                            <select name="nivel" class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg">
                                <option value="Principiante">Principiante</option>
                                <option value="Intermedio">Intermedio</option>
                                <option value="Avanzado">Avanzado</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                                Duración (horas)
                            </label>
                            <input type="number" name="duracion" step="0.5"
                                   class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none"
                                   placeholder="Ej: 2">
                        </div>
                    </div>
                    
                    <!-- Precio -->
                    <div>
                        <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                            Precio (MXN)
                        </label>
                        <input type="number" name="precio" required
                               class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none"
                               placeholder="Ej: 500">
                    </div>
                    
                    <!-- Botones -->
                    <div class="flex gap-3 pt-4">
                        <button type="submit" 
                                class="flex-1 bg-[#8B5CF6] text-white py-3 rounded-lg font-semibold hover:bg-[#8B5CF6]/90 transition">
                            Crear taller
                        </button>
                        <a href="/profile/me/profile" 
                           class="flex-1 border border-[#D9D9D9] text-[#1E1E1E] py-3 rounded-lg font-semibold text-center hover:bg-gray-50 transition">
                            Cancelar
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal del Mapa -->
<div id="mapModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl max-w-2xl w-full mx-4">
        <div class="p-4 border-b border-[#D9D9D9] flex justify-between items-center">
            <h3 class="text-xl font-bold text-[#1E1E1E]">Seleccionar ubicación</h3>
            <button onclick="closeMapModal()" class="text-[#1E1E1E]/60 hover:text-[#1E1E1E]">✕</button>
        </div>
        <div class="p-4">
            <div class="mb-4">
                <input type="text" id="locationSearch" 
                       placeholder="Buscar dirección..."
                       class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none">
                <div id="predictions" class="absolute bg-white border border-[#D9D9D9] rounded-lg mt-1 hidden z-10 w-[calc(100%-2rem)]"></div>
            </div>
            <div id="map" class="w-full h-96 rounded-lg mb-4"></div>
            <div id="selectedLocation" class="hidden">
                <p class="text-sm text-[#1E1E1E]/60 mb-2">Ubicación seleccionada:</p>
                <p id="selectedAddress" class="text-[#1E1E1E] font-medium"></p>
            </div>
            <div class="flex gap-3 mt-4">
                <button onclick="confirmLocation()" class="flex-1 bg-[#8B5CF6] text-white py-3 rounded-lg font-semibold hover:bg-[#8B5CF6]/90">Confirmar</button>
                <button onclick="closeMapModal()" class="flex-1 border border-[#D9D9D9] text-[#1E1E1E] py-3 rounded-lg hover:bg-gray-50">Cancelar</button>
            </div>
        </div>
    </div>
</div>

<script>
// Tabs de modalidad
const onlineTab = document.getElementById('onlineTab');
const presentialTab = document.getElementById('presentialTab');
const onlineFields = document.getElementById('onlineFields');
const presentialFields = document.getElementById('presentialFields');
const modalidadInput = document.getElementById('modalidad');

onlineTab.addEventListener('click', () => {
    onlineTab.classList.add('active');
    presentialTab.classList.remove('active');
    onlineFields.classList.add('active');
    presentialFields.classList.remove('active');
    modalidadInput.value = 'online';
});

presentialTab.addEventListener('click', () => {
    presentialTab.classList.add('active');
    onlineTab.classList.remove('active');
    presentialFields.classList.add('active');
    onlineFields.classList.remove('active');
    modalidadInput.value = 'presential';
});

// Materiales
function addMaterial() {
    const container = document.getElementById('materialesContainer');
    const div = document.createElement('div');
    div.className = 'flex gap-2';
    div.innerHTML = `
        <input type="text" name="materiales[]" placeholder="Ej: Guitarra"
               class="flex-1 px-3 py-2 border border-[#D9D9D9] rounded-lg">
        <button type="button" onclick="removeMaterial(this)" class="text-red-500">✕</button>
    `;
    container.appendChild(div);
}

function removeMaterial(btn) {
    btn.parentElement.remove();
}

// Módulos
function addModulo() {
    const container = document.getElementById('modulosContainer');
    const div = document.createElement('div');
    div.className = 'flex gap-2';
    div.innerHTML = `
        <input type="text" name="modulos[]" placeholder="Ej: Módulo 1: Introducción"
               class="flex-1 px-3 py-2 border border-[#D9D9D9] rounded-lg">
        <button type="button" onclick="removeModulo(this)" class="text-red-500">✕</button>
    `;
    container.appendChild(div);
}

function removeModulo(btn) {
    btn.parentElement.remove();
}

// Horarios
function addHorario() {
    const container = document.getElementById('horariosContainer');
    const div = document.createElement('div');
    div.className = 'flex gap-2';
    div.innerHTML = `
        <select name="horario_dia[]" class="flex-1 px-3 py-2 border border-[#D9D9D9] rounded-lg">
            <option value="Lunes">Lunes</option><option value="Martes">Martes</option>
            <option value="Miércoles">Miércoles</option><option value="Jueves">Jueves</option>
            <option value="Viernes">Viernes</option><option value="Sábado">Sábado</option>
            <option value="Domingo">Domingo</option>
        </select>
        <input type="time" name="horario_hora[]" class="px-3 py-2 border border-[#D9D9D9] rounded-lg">
        <button type="button" onclick="removeHorario(this)" class="text-red-500">✕</button>
    `;
    container.appendChild(div);
}

function removeHorario(btn) {
    btn.parentElement.remove();
}

// ===== MAPA =====
let map = null;
let marker = null;
let selectedLocationData = null;

async function initMap() {
    const { Loader } = await import('@googlemaps/js-api-loader');
    const loader = new Loader({ apiKey: '<%= process.env.GOOGLE_MAPS_API_KEY %>', version: 'weekly', libraries: ['places'] });
    await loader.load();
    
    map = new google.maps.Map(document.getElementById('map'), { center: { lat: 23.6345, lng: -102.5528 }, zoom: 5 });
    
    map.addListener('click', (e) => {
        setMarker(e.latLng);
        getAddressFromLatLng(e.latLng.lat(), e.latLng.lng());
    });
}

function setMarker(position) {
    if (marker) marker.setMap(null);
    marker = new google.maps.Marker({ position, map, draggable: true });
    marker.addListener('dragend', (e) => getAddressFromLatLng(e.latLng.lat(), e.latLng.lng()));
    map.setCenter(position);
    map.setZoom(15);
}

function getAddressFromLatLng(lat, lng) {
    const geocoder = new google.maps.Geocoder();
    geocoder.geocode({ location: { lat, lng } }, (results, status) => {
        if (status === 'OK' && results[0]) {
            selectedLocationData = { lat, lng, address: results[0].formatted_address };
            document.getElementById('selectedAddress').textContent = selectedLocationData.address;
            document.getElementById('selectedLocation').classList.remove('hidden');
        }
    });
}

function openMapModal() {
    document.getElementById('mapModal').classList.remove('hidden');
    document.getElementById('mapModal').classList.add('flex');
    if (!map) initMap();
    else google.maps.event.trigger(map, 'resize');
}

function closeMapModal() {
    document.getElementById('mapModal').classList.add('hidden');
    document.getElementById('mapModal').classList.remove('flex');
}

function confirmLocation() {
    if (selectedLocationData) {
        document.getElementById('direccion').value = selectedLocationData.address;
        document.getElementById('ubicacionLat').value = selectedLocationData.lat;
        document.getElementById('ubicacionLng').value = selectedLocationData.lng;
        document.getElementById('selectedLocationText').innerHTML = selectedLocationData.address;
        document.getElementById('selectedLocationDisplay').classList.remove('hidden');
        closeMapModal();
    }
}
</script>