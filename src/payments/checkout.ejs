<div class="max-w-4xl mx-auto py-12 px-4">
    <div class="grid md:grid-cols-2 gap-8">
        <!-- Resumen del curso -->
        <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] overflow-hidden">
            <img src="<%= course.imagenUrl %>" class="w-full h-48 object-cover">
            <div class="p-6">
                <h2 class="text-xl font-bold"><%= course.titulo %></h2>
                <p class="text-sm text-gray-500 mt-2"><%= course.descripcion %></p>
                <div class="border-t mt-4 pt-4">
                    <div class="flex justify-between">
                        <span>Total:</span>
                        <span class="text-2xl font-bold text-[#8B5CF6]">$<%= course.precio %> MXN</span>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Formulario de pago simulado -->
        <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-6">
            <h1 class="text-2xl font-bold mb-6">Completar pago</h1>
            
            <form method="POST" action="/payments/process-payment">
                <input type="hidden" name="cursoId" value="<%= course.id %>">
                
                <% if (course.horariosDisponibles && course.horariosDisponibles.length > 0) { %>
                    <div class="mb-4">
                        <label class="block text-sm font-medium mb-2">Selecciona tu horario</label>
                        <select name="horarioSeleccionado" class="w-full p-3 border rounded-lg">
                            <option value="">Selecciona</option>
                            <% course.horariosDisponibles.forEach(horario => { %>
                                <option value="<%= horario %>"><%= horario %></option>
                            <% }) %>
                        </select>
                    </div>
                <% } %>
                
                <div class="mb-4">
                    <label class="block text-sm font-medium mb-2">Comentarios (opcional)</label>
                    <textarea name="comentarios" rows="3" class="w-full p-3 border rounded-lg"></textarea>
                </div>
                
                <!-- Métodos de pago simulados -->
                <div class="mb-6">
                    <label class="block text-sm font-medium mb-2">Método de pago</label>
                    <div class="space-y-2">
                        <label class="flex items-center gap-2 p-3 border rounded-lg cursor-pointer">
                            <input type="radio" name="metodoPago" value="simulado" checked>
                            <span>💳 Pago simulado (Demo)</span>
                        </label>
                    </div>
                    <p class="text-xs text-gray-500 mt-2">⚠️ Modo demostración - No se realizará ningún cargo real</p>
                </div>
                
                <button type="submit" class="w-full bg-[#8B5CF6] text-white py-3 rounded-lg font-semibold">
                    Confirmar pago - $<%= course.precio %> MXN
                </button>
            </form>
        </div>
    </div>
</div>