<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] overflow-hidden">
        <div class="p-6">
            <h1 class="text-2xl font-bold text-[#1E1E1E] mb-6">Agregar descripción</h1>
            
            <div class="mb-6">
                <img src="<%= imageUrl %>" class="w-full rounded-lg" alt="Preview">
            </div>
            
            <form method="POST" action="/posts/create">
                <input type="hidden" name="imageUrl" value="<%= imageUrl %>">
                <input type="hidden" name="imagePublicId" value="<%= imagePublicId %>">
                
                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                            Descripción
                        </label>
                        <textarea 
                            name="descripcion"
                            rows="4"
                            class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#FB923C] focus:border-transparent outline-none resize-none"
                            placeholder="Cuéntanos sobre tu proyecto..."></textarea>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                            Etiquetas (separadas por comas)
                        </label>
                        <input 
                            type="text" 
                            name="etiquetas"
                            class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#FB923C] focus:border-transparent outline-none"
                            placeholder="pintura, warhammer, arte">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                            Ubicación (opcional)
                        </label>
                        <input 
                            type="text" 
                            name="ubicacion"
                            class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#FB923C] focus:border-transparent outline-none"
                            placeholder="Ciudad, país o lugar">
                    </div>
                    
                    <button type="submit" class="w-full bg-[#FB923C] text-white py-3 rounded-lg font-semibold hover:bg-[#FB923C]/90 transition">
                        Publicar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>