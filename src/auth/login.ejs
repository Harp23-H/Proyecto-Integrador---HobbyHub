<style>
    .input-field {
        transition: all 0.2s ease;
    }
    .input-field:focus {
        transform: translateY(-1px);
    }
    .btn-login {
        transition: all 0.2s ease;
    }
    .btn-login:hover {
        transform: translateY(-1px);
    }
</style>

<div class="min-h-[calc(100vh-4rem)] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
        <!-- Logo o título -->
        <div class="text-center">
            <div class="flex justify-center mb-4">
                <div class="w-20 h-20 bg-gradient-to-br from-[#8B5CF6] to-[#C4B5FD] rounded-2xl flex items-center justify-center">
                    <span class="text-3xl font-bold text-white">HH</span>
                </div>
            </div>
            <h2 class="text-3xl font-extrabold text-[#1E1E1E]">
                Bienvenido a HobbyHub
            </h2>
            <p class="mt-2 text-sm text-[#1E1E1E]/70">
                Conecta con personas que comparten tus mismos hobbies
            </p>
        </div>

        <!-- Mostrar mensaje de éxito después de registro -->
        <% if (message) { %>
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg text-sm" role="alert">
                <span class="block sm:inline">✅ <%= message %></span>
            </div>
        <% } %>

        <!-- Mostrar errores -->
        <% if (errors && errors.length > 0) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg text-sm" role="alert">
                <% errors.forEach(error => { %>
                    <p>❌ <%= error.msg %></p>
                <% }) %>
            </div>
        <% } %>

        <!-- Formulario de login -->
        <form class="mt-8 space-y-6" action="/auth/login" method="POST">
            <div class="space-y-4">
                <!-- Campo de email -->
                <div>
                    <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                        Correo Electrónico
                    </label>
                    <input 
                        type="email" 
                        name="email"
                        value="<%= oldData && oldData.email ? oldData.email : '' %>"
                        required
                        class="input-field w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none transition"
                        placeholder="ejemplo@correo.com"
                        autocomplete="email"
                    >
                </div>

                <!-- Campo de contraseña -->
                <div>
                    <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                        Contraseña
                    </label>
                    <input 
                        type="password" 
                        name="password"
                        required
                        class="input-field w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none transition"
                        placeholder="••••••••"
                        autocomplete="current-password"
                    >
                </div>
            </div>

            <!-- Enlace de olvidé contraseña -->
            <div class="flex items-center justify-end">
                <a href="#" class="text-sm text-[#8B5CF6] hover:text-[#8B5CF6]/80 transition">
                    ¿Olvidaste tu contraseña?
                </a>
            </div>

            <!-- Botón de inicio de sesión -->
            <button 
                type="submit" 
                class="btn-login w-full flex justify-center py-3 px-4 border border-transparent rounded-lg text-white bg-[#8B5CF6] hover:bg-[#8B5CF6]/90 font-medium text-lg transition shadow-md hover:shadow-lg"
            >
                Iniciar Sesión
            </button>

            <!-- Link de registro -->
            <p class="text-center text-sm text-[#1E1E1E]">
                ¿No tienes una cuenta? 
                <a href="/auth/register" class="font-medium text-[#8B5CF6] hover:text-[#8B5CF6]/80 transition">
                    Crea una cuenta
                </a>
            </p>
        </form>

        <!-- Términos y condiciones -->
        <p class="text-xs text-center text-[#1E1E1E]/40 mt-8">
            Al iniciar sesión, aceptas nuestros 
            <a href="#" class="text-[#8B5CF6] hover:underline">Términos de Servicio</a> y 
            <a href="#" class="text-[#8B5CF6] hover:underline">Política de Privacidad</a>
        </p>
    </div>
</div>