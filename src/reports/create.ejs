<div class="max-w-lg mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-6">
        <div class="text-center mb-6">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-[#1E1E1E]">Reportar contenido</h1>
            <p class="text-[#1E1E1E]/60 text-sm mt-1">
                Ayúdanos a mantener segura la comunidad
            </p>
        </div>
        
        <% if (errors && errors.length > 0) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                <% errors.forEach(error => { %>
                    <p><%= error.msg %></p>
                <% }) %>
            </div>
        <% } %>
        
        <form method="POST" action="/reports/create">
            <input type="hidden" name="tipo" value="<%= tipo %>">
            <input type="hidden" name="contenidoId" value="<%= contenidoId %>">
            
            <!-- Motivo del reporte -->
            <div class="mb-6">
                <label class="block text-sm font-medium text-[#1E1E1E] mb-3">
                    Motivo del reporte *
                </label>
                <div class="space-y-3">
                    <label class="flex items-center gap-3 p-3 border border-[#D9D9D9] rounded-lg cursor-pointer hover:bg-[#EDE9FE] transition">
                        <input type="radio" name="motivo" value="contenido_inapropiado" required>
                        <span>Contenido inapropiado</span>
                    </label>
                    <label class="flex items-center gap-3 p-3 border border-[#D9D9D9] rounded-lg cursor-pointer hover:bg-[#EDE9FE] transition">
                        <input type="radio" name="motivo" value="spam">
                        <span>Spam</span>
                    </label>
                    <label class="flex items-center gap-3 p-3 border border-[#D9D9D9] rounded-lg cursor-pointer hover:bg-[#EDE9FE] transition">
                        <input type="radio" name="motivo" value="acoso">
                        <span>Acoso</span>
                    </label>
                    <label class="flex items-center gap-3 p-3 border border-[#D9D9D9] rounded-lg cursor-pointer hover:bg-[#EDE9FE] transition">
                        <input type="radio" name="motivo" value="informacion_falsa">
                        <span>Información falsa</span>
                    </label>
                    <label class="flex items-center gap-3 p-3 border border-[#D9D9D9] rounded-lg cursor-pointer hover:bg-[#EDE9FE] transition">
                        <input type="radio" name="motivo" value="discurso_odio">
                        <span>Discurso de odio</span>
                    </label>
                    <label class="flex items-center gap-3 p-3 border border-[#D9D9D9] rounded-lg cursor-pointer hover:bg-[#EDE9FE] transition">
                        <input type="radio" name="motivo" value="otro">
                        <span>Otro</span>
                    </label>
                </div>
            </div>
            
            <!-- Descripción adicional -->
            <div class="mb-6">
                <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                    Descripción (opcional)
                </label>
                <textarea name="descripcion" rows="4"
                          class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none"
                          placeholder="Escribe más detalles aquí..."></textarea>
            </div>
            
            <!-- Botones -->
            <div class="flex gap-3">
                <button type="submit" 
                        class="flex-1 bg-[#8B5CF6] text-white py-3 rounded-lg font-semibold hover:bg-[#8B5CF6]/90 transition">
                    Enviar reporte
                </button>
                <a href="javascript:history.back()" 
                   class="flex-1 border border-[#D9D9D9] text-[#1E1E1E] py-3 rounded-lg font-semibold text-center hover:bg-gray-50 transition">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>