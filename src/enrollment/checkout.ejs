<div class="max-w-4xl mx-auto">
    <div class="grid md:grid-cols-2 gap-6">
        <!-- Resumen del curso -->
        <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] overflow-hidden sticky top-4 h-fit">
            <img src="<%= course.imagenUrl %>" class="w-full h-48 object-cover">
            <div class="p-6">
                <h2 class="text-xl font-bold text-[#1E1E1E] mb-2"><%= course.titulo %></h2>
                <p class="text-sm text-[#1E1E1E]/60 mb-4"><%= course.descripcion.substring(0, 150) %>...</p>
                
                <div class="space-y-3">
                    <div class="flex justify-between">
                        <span class="text-[#1E1E1E]/60">Modalidad:</span>
                        <span class="font-semibold text-[#1E1E1E]">
                            <%= course.modalidad === 'presencial' ? '📍 Presencial' : '💻 En línea' %>
                        </span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-[#1E1E1E]/60">Duración:</span>
                        <span class="font-semibold text-[#1E1E1E]"><%= course.duracion %> horas</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-[#1E1E1E]/60">Nivel:</span>
                        <span class="font-semibold text-[#1E1E1E]"><%= course.nivel %></span>
                    </div>
                    <div class="flex justify-between border-t border-[#D9D9D9] pt-3">
                        <span class="text-lg font-bold text-[#1E1E1E]">Total:</span>
                        <span class="text-2xl font-bold text-[#8B5CF6]">$<%= course.precio %> MXN</span>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Formulario de contratación -->
        <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-6">
            <h1 class="text-2xl font-bold text-[#1E1E1E] mb-6">Completar contratación</h1>
            
            <% if (errors && errors.length > 0) { %>
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                    <% errors.forEach(error => { %>
                        <p><%= error.msg %></p>
                    <% }) %>
                </div>
            <% } %>
            
            <form method="POST" action="/enrollment/checkout/<%= course.id %>">
                <div class="space-y-6">
                    <!-- Horarios disponibles (si aplica) -->
                    <% if (course.horariosDisponibles && course.horariosDisponibles.length > 0) { %>
                        <div>
                            <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                                Selecciona un horario *
                            </label>
                            <select name="horarioSeleccionado" required
                                    class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none">
                                <option value="">Selecciona un horario</option>
                                <% course.horariosDisponibles.forEach(horario => { %>
                                    <option value="<%= horario %>"><%= horario %></option>
                                <% }) %>
                            </select>
                        </div>
                    <% } %>
                    
                    <!-- Datos del alumno -->
                    <div class="bg-[#EDE9FE] p-4 rounded-lg">
                        <h3 class="font-semibold text-[#1E1E1E] mb-3">Datos del alumno</h3>
                        <p><strong>Nombre:</strong> <%= user.nombres %> <%= user.apellidos %></p>
                        <p><strong>Email:</strong> <%= user.email %></p>
                        <p><strong>Usuario:</strong> @<%= user.username %></p>
                    </div>
                    
                    <!-- Comentarios adicionales -->
                    <div>
                        <label class="block text-sm font-medium text-[#1E1E1E] mb-2">
                            Comentarios adicionales (opcional)
                        </label>
                        <textarea name="comentarios" rows="3"
                                  class="w-full px-4 py-3 border border-[#D9D9D9] rounded-lg focus:ring-2 focus:ring-[#8B5CF6] focus:border-transparent outline-none"
                                  placeholder="¿Alguna pregunta o comentario para el experto?"></textarea>
                    </div>
                    
                    <!-- Términos y condiciones -->
                    <div class="flex items-start gap-2">
                        <input type="checkbox" id="terminos" required class="mt-1">
                        <label for="terminos" class="text-sm text-[#1E1E1E]/70">
                            Acepto los <a href="#" class="text-[#8B5CF6]">términos y condiciones</a> y confirmo que los datos son correctos.
                        </label>
                    </div>
                    
                    <button type="submit" 
                            class="w-full bg-[#8B5CF6] text-white py-3 rounded-lg font-semibold hover:bg-[#8B5CF6]/90 transition">
                        Confirmar y pagar $<%= course.precio %> MXN
                    </button>
                    
                    <a href="/courses/<%= course.id %>" 
                       class="block text-center text-[#1E1E1E]/60 hover:text-[#1E1E1E] text-sm">
                        ← Volver al curso
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>