<div class="max-w-lg mx-auto text-center">
    <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-8">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M5 13l4 4L19 7" />
            </svg>
        </div>
        
        <h2 class="text-2xl font-bold text-[#1E1E1E] mb-2">¡Contratación exitosa!</h2>
        <p class="text-[#1E1E1E]/60 mb-6">
            Has sido inscrito exitosamente en el curso.
        </p>
        
        <div class="bg-[#EDE9FE] p-4 rounded-lg text-left mb-6">
            <h3 class="font-semibold text-[#1E1E1E] mb-2">Detalles de la inscripción:</h3>
            <p><strong>Curso:</strong> <%= enrollment.curso.titulo %></p>
            <p><strong>Modalidad:</strong> <%= enrollment.curso.modalidad === 'presencial' ? 'Presencial' : 'En línea' %></p>
            <% if (enrollment.horarioSeleccionado) { %>
                <p><strong>Horario:</strong> <%= enrollment.horarioSeleccionado %></p>
            <% } %>
            <p><strong>Monto pagado:</strong> $<%= enrollment.montoPagado %> MXN</p>
            <p><strong>Fecha de inscripción:</strong> <%= new Date(enrollment.fechaInscripcion).toLocaleDateString('es-MX') %></p>
        </div>
        
        <div class="space-y-3">
            <a href="/enrollment/my/enrollments" 
               class="block w-full bg-[#8B5CF6] text-white py-3 rounded-lg font-semibold hover:bg-[#8B5CF6]/90 transition">
                Ver mis contrataciones
            </a>
            <a href="/courses/<%= enrollment.curso.id %>" 
               class="block w-full border border-[#8B5CF6] text-[#8B5CF6] py-3 rounded-lg font-semibold hover:bg-[#EDE9FE] transition">
                Ver detalles del curso
            </a>
        </div>
    </div>
</div>