<div class="max-w-4xl mx-auto">
    <!-- Portada -->
    <div class="relative">
        <div class="h-48 bg-gradient-to-r from-[#8B5CF6] to-[#FFF59D] rounded-t-xl"></div>
        
        <!-- Foto de perfil -->
        <div class="absolute -bottom-12 left-6">
            <img src="<%= profileUser.fotoPerfil %>" 
                 class="w-24 h-24 rounded-full border-4 border-white object-cover">
        </div>
        
        <!-- Botón de seguir/editar -->
        <div class="absolute bottom-4 right-6">
            <% if (isOwnProfile) { %>
                <a href="/profile/me/edit" 
                   class="bg-[#8B5CF6] text-white px-6 py-2 rounded-lg hover:bg-[#8B5CF6]/90 transition">
                    Editar perfil
                </a>
            <% } else { %>
                <button onclick="toggleFollow()" 
                        id="followBtn"
                        class="<%= isFollowing ? 'bg-[#1E1E1E] text-white' : 'bg-[#8B5CF6] text-white' %> px-6 py-2 rounded-lg hover:opacity-90 transition">
                    <%= isFollowing ? 'Siguiendo' : 'Seguir' %>
                </button>
            <% } %>
        </div>
    </div>
    
    <!-- Información del perfil -->
    <div class="bg-white rounded-b-xl shadow-sm border border-[#D9D9D9] border-t-0 p-6 pt-16">
        <h1 class="text-2xl font-bold text-[#1E1E1E]">
            <%= profileUser.nombres %> <%= profileUser.apellidos %>
        </h1>
        <p class="text-[#1E1E1E]/60 mb-2">@<%= profileUser.username %></p>
        
        <% if (profileUser.bio) { %>
            <p class="text-[#1E1E1E] mb-4"><%= profileUser.bio %></p>
        <% } %>
        
        <!-- Estadísticas -->
        <div class="flex gap-6 mb-4">
            <div>
                <span class="font-bold text-[#1E1E1E]"><%= profileUser.seguidoresCount || 0 %></span>
                <span class="text-[#1E1E1E]/60"> seguidores</span>
            </div>
            <div>
                <span class="font-bold text-[#1E1E1E]"><%= profileUser.seguidosCount || 0 %></span>
                <span class="text-[#1E1E1E]/60"> seguidos</span>
            </div>
        </div>
        
        <!-- Hobbies -->
        <% if (profileUser.hobbies && profileUser.hobbies.length > 0) { %>
            <div class="flex flex-wrap gap-2 mb-4">
                <% profileUser.hobbies.forEach(hobby => { %>
                    <span class="bg-[#FFF59D] text-[#1E1E1E] px-3 py-1 rounded-full text-sm">
                        <%= hobby %>
                    </span>
                <% }) %>
            </div>
        <% } %>
        
        <!-- Redes sociales -->
        <% if (profileUser.instagram || profileUser.twitter || profileUser.tiktok) { %>
            <div class="flex gap-3">
                <% if (profileUser.instagram) { %>
                    <a href="https://instagram.com/<%= profileUser.instagram %>" target="_blank" class="text-[#1E1E1E]/60 hover:text-[#8B5CF6]">
                        Instagram
                    </a>
                <% } %>
                <% if (profileUser.twitter) { %>
                    <a href="https://twitter.com/<%= profileUser.twitter %>" target="_blank" class="text-[#1E1E1E]/60 hover:text-[#8B5CF6]">
                        Twitter
                    </a>
                <% } %>
                <% if (profileUser.tiktok) { %>
                    <a href="https://tiktok.com/@<%= profileUser.tiktok %>" target="_blank" class="text-[#1E1E1E]/60 hover:text-[#8B5CF6]">
                        TikTok
                    </a>
                <% } %>
            </div>
        <% } %>
    </div>
    
    <!-- Publicaciones del usuario -->
    <div class="mt-6 space-y-4">
        <h2 class="text-xl font-bold text-[#1E1E1E]">Publicaciones</h2>
        
        <% if (posts && posts.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <% posts.forEach(post => { %>
                    <a href="/feed/post/<%= post.id %>" class="block">
                        <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] overflow-hidden hover:shadow-md transition">
                            <img src="<%= post.imagenUrl %>" class="w-full h-64 object-cover">
                            <% if (post.descripcion) { %>
                                <div class="p-3">
                                    <p class="text-sm text-[#1E1E1E] line-clamp-2"><%= post.descripcion %></p>
                                </div>
                            <% } %>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <div class="bg-white rounded-xl shadow-sm border border-[#D9D9D9] p-8 text-center">
                <p class="text-[#1E1E1E]/60">No hay publicaciones aún</p>
            </div>
        <% } %>
    </div>
</div>

<script>
async function toggleFollow() {
    const username = '<%= profileUser.username %>';
    const btn = document.getElementById('followBtn');
    const isFollowing = btn.textContent === 'Siguiendo';
    
    const url = isFollowing ? `/profile/${username}/unfollow` : `/profile/${username}/follow`;
    
    try {
        const response = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const data = await response.json();
        
        if (data.success) {
            if (data.following) {
                btn.textContent = 'Siguiendo';
                btn.classList.remove('bg-[#8B5CF6]');
                btn.classList.add('bg-[#1E1E1E]');
            } else {
                btn.textContent = 'Seguir';
                btn.classList.remove('bg-[#1E1E1E]');
                btn.classList.add('bg-[#8B5CF6]');
            }
            location.reload();
        }
    } catch (error) {
        console.error('Error:', error);
    }
}
</script>